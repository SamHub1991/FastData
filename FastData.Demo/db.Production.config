<?xml version="1.0" encoding="utf-8"?>
<!-- Production Environment Configuration -->
<!-- This file overrides db.config when ASPNETCORE_ENVIRONMENT=Production -->
<!-- For security, use environment variables for sensitive data: -->
<!--   FASTDATA_CONN_SQLSERVER=server=...;database=...;uid=...;pwd=... -->
<!--   FASTDATA_CONN_MYSQL=server=...;database=...;uid=...;pwd=... -->
<!--   FASTDATA_CONN_POSTGRESQL=server=...;database=...;uid=...;pwd=... -->
<configuration>
  <configSections>
    <section name="DataConfig" type="FastData.Config.DataConfig, FastData" />
  </configSections>
  <DataConfig Default="SqlServer">
    <Connections>
      <Add Key="SqlServer" 
           Provider="Microsoft.Data.SqlClient" 
           ConnStr="server=prod-sql-server;database=FastDataDemo;uid=app_user;pwd=CHANGE_ME;TrustServerCertificate=true" 
           IsDefault="true" />
      <Add Key="MySql" 
           Provider="MySql.Data.MySqlClient" 
           ConnStr="server=prod-mysql-server;database=FastDataDemo;uid=app_user;pwd=CHANGE_ME" />
      <Add Key="Sqlite" 
           Provider="System.Data.SQLite" 
           ConnStr="Data Source=/data/fastdata_prod.db" />
      <Add Key="PostgreSql" 
           Provider="Npgsql" 
           ConnStr="server=prod-pg-server;database=fastdatademo;uid=app_user;pwd=CHANGE_ME" />
    </Connections>
  </DataConfig>
</configuration>

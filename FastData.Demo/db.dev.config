<?xml version="1.0" encoding="utf-8"?>
<!--
  ================================================================================
  FastData Demo 开发环境配置
  
  配置说明：
  - 本文件为开发环境（dev）专用配置
  - 通过 db.config 中的 Active="dev" 自动加载
  - 连接节点只需要 Key、Provider、ConnStr；其他属性都有默认值，按需覆盖
  ================================================================================
-->
<DataConfig Default="SqlServer">
  <Connections>
    <!-- 必填：Key、Provider、ConnStr。可选项默认值见 FastData.Example/db.dev.config。 -->
    <Add Key="SqlServer" Provider="Microsoft.Data.SqlClient"
         ConnStr="server=127.0.0.1,1433;database=FastDataDemo;uid=sa;pwd=FastData@Test123;TrustServerCertificate=true;Encrypt=False"
         IsDefault="true" DesignModel="CodeFirst" />
    
    <Add Key="Sqlite" Provider="Microsoft.Data.Sqlite"
         ConnStr="Data Source=./demo_data.db" />
    
    <!-- MySQL: 多数据库支持 -->
    <Add Key="MySql" Provider="MySql.Data.MySqlClient"
         ConnStr="server=127.0.0.1;database=FastDataDemo;uid=root;pwd=FastData@Test123;SslMode=None"
         CacheType="redis" DesignModel="CodeFirst" />
    
    <!-- PostgreSQL: 多数据库支持 -->
    <Add Key="PostgreSql" Provider="Npgsql"
         ConnStr="server=127.0.0.1;database=fastdatademo;uid=postgres;pwd=FastData@Test123"
         CacheType="redis" DesignModel="CodeFirst" />
    
  </Connections>
  
  <!-- 
    Redis 配置（开发环境）
    
    属性说明：
    - WriteServerList: 写服务器列表（格式：ip:port，多个用逗号分隔）
    - ReadServerList: 读服务器列表（格式：ip:port，多个用逗号分隔）
    - MaxWritePoolSize: 最大写连接数（建议：60-200）
    - MaxReadPoolSize: 最大读连接数（建议：60-200）
    - AutoStart: 是否自动启动连接池（true/false）
    - Password: Redis 密码（无密码可省略此属性）
    - Db: Redis 数据库索引（默认 0，范围 0-15）
    - ConnectTimeout: 连接超时（毫秒，默认 5000）
    - SyncTimeout: 同步超时（毫秒，默认 5000）
    - ResponseTimeout: 响应超时（毫秒，默认 5000）
  -->
  <RedisConfig
    WriteServerList="127.0.0.1:6379"
    ReadServerList="127.0.0.1:6379"
    MaxWritePoolSize="60"
    MaxReadPoolSize="60"
    AutoStart="true" />
  
  <!-- 
    连接池配置（开发环境）
    
    属性说明：
    - MinPoolSize: 最小连接数（建议：10-20，开发环境可设较大值）
    - MaxPoolSize: 最大连接数（建议：100-200，根据服务器资源调整）
    - ConnectionTimeout: 连接超时时间，单位秒（建议：10-30）
    - ConnectionLifetime: 连接生命周期，单位分钟（建议：15-30，0表示不限制）
    - HealthCheckInterval: 健康检查间隔，单位秒（建议：30-60）
    - LeakDetectionThreshold: 泄漏检测阈值，单位秒（建议：120-300，超过此时间未释放的连接会被记录）
    - EnableSmartAdjustment: 是否启用智能调整（true/false，根据负载自动扩缩容）
    - LoadThreshold: 扩容阈值，百分比（建议：70-85，负载超过此值时扩容）
    - ShrinkThreshold: 缩容阈值，百分比（建议：20-35，负载低于此值时缩容）
    - MaxRetries: 连接创建最大重试次数（建议：2-5）
    - RetryBaseDelayMs: 重试基础延迟，单位毫秒（建议：50-200，采用指数退避策略）
    - ValidationCommandTimeout: 连接验证命令超时，单位秒（建议：3-5）
    - SmartAdjustmentInterval: 智能调整间隔，单位秒（建议：15-60）
    - MaxExpandCount: 每次最大扩容数量（建议：5-10）
    - MaxShrinkCount: 每次最大缩容数量（建议：3-5）
    - CircuitBreakerEnabled: 是否启用熔断器（true/false，建议开启）
    - CircuitBreakerFailureThreshold: 连续失败阈值，达到此值触发熔断（建议：3-5）
    - CircuitBreakerOpenDurationSec: 熔断时长，单位秒（建议：30-60，之后进入半开状态）
    - CircuitBreakerHalfOpenMaxRequests: 半开状态下允许的最大测试请求数（建议：3-5）
    - ErrorShrinkThreshold: 异常缩容阈值，连续失败次数（建议：3-5）
    - ErrorShrinkPercentage: 异常缩容比例，百分比（建议：20-50）
    - EnableRedisCheck: 是否启用 Redis 可用性检测（true/false，Redis 可用时才允许扩容）
    - RedisConnectionString: Redis 连接字符串（用于可用性检测）
  -->
  <ConnectionPool
    MinPoolSize="2"
    MaxPoolSize="100"
    CircuitBreakerEnabled="false" />
  
  <!-- 
    IM 平台配置（开发环境）
    
    用于异常通知和远程指令管理
    支持 QQ 机器人、企业微信、钉钉等 IM 平台
  -->
  <IMPlatform>
    <!-- 
      QQ 机器人配置
      
      属性说明：
      - IsEnabled: 是否启用 QQ 机器人（true/false）
      - BotId: 机器人 ID（QQ 号）
      - BotToken: 机器人 Token（用于 API 认证）
      - ApiUrl: API 地址（如 http://127.0.0.1:5700，Go-CQHTTP 默认端口）
      - CommandPrefix: 指令前缀（默认 #，如 #status）
      - RequireAdminForCommands: 是否需要管理员权限才能执行指令（true/false）
      
      子节点说明：
      - AdminQQNumbers: 管理员 QQ 号列表
      - NotifyGroups: 通知群号列表（异常信息会发送到这些群）
      - NotifyUsers: 通知个人 QQ 号列表（异常信息会发送给这些用户）
    -->
    <QQBot 
      IsEnabled="false" 
      BotId="" 
      BotToken="" 
      ApiUrl="http://127.0.0.1:5700" 
      CommandPrefix="#" 
      RequireAdminForCommands="true">
      <AdminQQNumbers>
        <!-- <Add Value="123456789" /> -->
      </AdminQQNumbers>
      <NotifyGroups>
        <!-- <Add Value="987654321" /> -->
      </NotifyGroups>
      <NotifyUsers>
        <!-- <Add Value="111222333" /> -->
      </NotifyUsers>
    </QQBot>
    
    <!-- 
      异常通知配置
      
      属性说明：
      - IsEnabled: 是否启用异常通知（true/false）
      - MinNotifyIntervalSeconds: 最小通知间隔，单位秒（建议：60-300，防止重复通知）
      - SendStackTrace: 是否发送堆栈信息（true/false，调试时建议开启）
      - MaxStackTraceLength: 最大堆栈长度（建议：500-1000，过长会被截断）
      - MinLevel: 只通知指定级别以上的异常（可选值：Debug, Info, Warning, Error, Critical）
    -->
    <ExceptionNotify 
      IsEnabled="true" 
      MinNotifyIntervalSeconds="60" 
      SendStackTrace="true" 
      MaxStackTraceLength="500" 
      MinLevel="Error" />
  </IMPlatform>
</DataConfig>

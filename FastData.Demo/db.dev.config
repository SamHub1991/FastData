<?xml version="1.0" encoding="utf-8"?>
<!--
  ================================================================================
  FastData 开发环境数据库配置
  
  配置说明：
  - 本文件为开发环境（dev）专用配置
  - 默认加载 db.config，如存在 db.{env}.config 且 ActiveEnv 设置匹配则优先加载
  - Redis 默认使用 db=7 用于开发环境隔离
  
  连接池配置（可选）：
    基础配置:
      - MinPoolSize: 最小连接数（默认 10，开发环境建议 5-10）
      - MaxPoolSize: 最大连接数（默认 100，开发环境建议 20-50）
      - ConnectionTimeout: 获取连接超时秒数（默认 30）
    智能调整:
      - EnableSmartAdjustment: 是否启用智能调整（默认 true）
      - LoadThreshold: 扩容阈值百分比（默认 80）
      - ShrinkThreshold: 缩容阈值百分比（默认 30）
    熔断器:
      - CircuitBreakerEnabled: 是否启用熔断器（默认 true）
      - CircuitBreakerFailureThreshold: 连续失败阈值（默认 5）
      - CircuitBreakerOpenDurationSec: 熔断时长秒数（默认 30）
  ================================================================================
-->
<DataConfig Default="SqlServer">
  <Connections>
    <!-- SQL Server: 主数据库 -->
    <Add Key="SqlServer" Provider="Microsoft.Data.SqlClient"
         ConnStr="server=localhost;database=FastDataDemo;uid=sa;pwd=FastData@Test123;TrustServerCertificate=true;Max Pool Size=200;Min Pool Size=10;Connect Timeout=10;Command Timeout=30"
         IsDefault="true" />
    <!-- MySQL: 多数据库支持 -->
    <Add Key="MySql" Provider="MySql.Data.MySqlClient"
         ConnStr="server=127.0.0.1;database=FastDataDemo;uid=root;pwd=FastData@Test123;MaximumPoolSize=200;MinimumPoolSize=10;ConnectionTimeout=10;DefaultCommandTimeout=30;SslMode=None" />
    <!-- PostgreSQL: 多数据库支持 -->
    <Add Key="PostgreSql" Provider="Npgsql"
         ConnStr="server=127.0.0.1;database=fastdatademo;uid=postgres;pwd=postgres;Maximum Pool Size=200;Minimum Pool Size=10;Timeout=10;Command Timeout=30" />
    <!-- SQLite: 本地文件数据库 -->
    <Add Key="Sqlite" Provider="System.Data.SQLite"
         ConnStr="Data Source=fastdata_demo.db" />
  </Connections>
  <!-- Redis 缓存配置：开发环境使用 db=7 隔离 -->
  <Redis Server="127.0.0.1:6379" Db="7" />
  <!-- 连接池配置（开发环境优化） -->
  <ConnectionPool
    MinPoolSize="5"
    MaxPoolSize="40"
    ConnectionTimeout="30"
    ConnectionLifetime="30"
    HealthCheckInterval="60"
    LeakDetectionThreshold="300"
    LoadThreshold="80"
    ShrinkThreshold="30"
    MaxRetries="3"
    RetryBaseDelayMs="50"
    ValidationCommandTimeout="5"
    SmartAdjustmentInterval="30"
    MaxExpandCount="10"
    MaxShrinkCount="5"
    EnableSmartAdjustment="true"
    CircuitBreakerEnabled="true"
    CircuitBreakerFailureThreshold="5"
    CircuitBreakerOpenDurationSec="30"
    CircuitBreakerHalfOpenMaxRequests="3" />
</DataConfig>

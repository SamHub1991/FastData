<?xml version="1.0" encoding="utf-8"?>
<!-- Development Environment Configuration -->
<!-- This file overrides db.config when ASPNETCORE_ENVIRONMENT=Development -->
<configuration>
  <configSections>
    <section name="DataConfig" type="FastData.Config.DataConfig, FastData" />
  </configSections>
  <DataConfig Default="SqlServer">
    <Connections>
      <Add Key="SqlServer" 
           Provider="Microsoft.Data.SqlClient" 
           ConnStr="server=localhost;database=FastDataDemo_Dev;uid=sa;pwd=DevPassword123;TrustServerCertificate=true" 
           IsDefault="true" />
      <Add Key="MySql" 
           Provider="MySql.Data.MySqlClient" 
           ConnStr="server=127.0.0.1;database=FastDataDemo_Dev;uid=root;pwd=DevPassword123" />
      <Add Key="Sqlite" 
           Provider="System.Data.SQLite" 
           ConnStr="Data Source=fastdata_dev.db" />
      <Add Key="PostgreSql" 
           Provider="Npgsql" 
           ConnStr="server=127.0.0.1;database=fastdatademo_dev;uid=postgres;pwd=postgres" />
    </Connections>
  </DataConfig>
</configuration>

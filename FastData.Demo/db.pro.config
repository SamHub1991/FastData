<?xml version="1.0" encoding="utf-8"?>
<!--
  ================================================================================
  FastData 生产环境数据库配置
  
  配置说明：
  - 本文件为生产环境（pro）专用配置
  - 生产环境应使用更强的密码和更严格的连接池限制
  - Redis 默认使用 db=0（生产环境主库）
  
  生产环境建议：
  - MinPoolSize: 根据并发量设置（建议 20-50）
  - MaxPoolSize: 根据数据库 max_connections 设置（建议 100-200）
  - ConnectionTimeout: 可适当缩短（建议 15-30 秒）
  - 启用熔断器防止雪崩（CircuitBreakerEnabled=true）
  ================================================================================
-->
<DataConfig Default="SqlServer">
  <Connections>
    <!-- SQL Server: 主数据库（生产环境） -->
    <Add Key="SqlServer" Provider="Microsoft.Data.SqlClient"
         ConnStr="server=localhost;database=FastDataDemo;uid=sa;pwd=FastData@Test123;TrustServerCertificate=true"
         IsDefault="true" />
    <!-- MySQL: 多数据库支持 -->
    <Add Key="MySql" Provider="MySql.Data.MySqlClient"
         ConnStr="server=127.0.0.1;database=FastDataDemo;uid=root;pwd=FastData@Test123" />
    <!-- PostgreSQL: 多数据库支持 -->
    <Add Key="PostgreSql" Provider="Npgsql"
         ConnStr="server=127.0.0.1;database=fastdatademo;uid=postgres;pwd=postgres" />
  </Connections>
  <!-- Redis 缓存配置：生产环境使用 db=0 -->
  <Redis Server="127.0.0.1:6379" Db="0" />
  <!-- 连接池配置（生产环境优化） -->
  <ConnectionPool
    MinPoolSize="20"
    MaxPoolSize="150"
    ConnectionTimeout="20"
    ConnectionLifetime="60"
    HealthCheckInterval="30"
    LeakDetectionThreshold="120"
    LoadThreshold="70"
    ShrinkThreshold="20"
    MaxRetries="5"
    RetryBaseDelayMs="100"
    ValidationCommandTimeout="3"
    SmartAdjustmentInterval="15"
    MaxExpandCount="20"
    MaxShrinkCount="10"
    EnableSmartAdjustment="true"
    CircuitBreakerEnabled="true"
    CircuitBreakerFailureThreshold="3"
    CircuitBreakerOpenDurationSec="60"
    CircuitBreakerHalfOpenMaxRequests="5" />
</DataConfig>

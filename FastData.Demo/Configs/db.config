<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <configSections>
    <section name="DataConfig" type="FastData.Config.DataConfig,FastData" />
    <section name="RedisConfig" type="FastRedis.Config.RedisConfig,FastRedis" />
  </configSections>

  <!-- 数据库配置 -->
  <DataConfig Default="DefaultDb">
    <Connections>
      <!-- SQL Server -->
      <Add Provider="SqlServer" 
           Key="DefaultDb" 
           ConnStr="server=.;database=FastDataDemo;uid=sa;pwd=YourPassword123" 
           IsDefault="true" 
           DesignModel="DbFirst" 
           CacheType="web" />
      
      <!-- MySQL -->
      <Add Provider="MySql" 
           Key="MySqlDb" 
           ConnStr="server=127.0.0.1;database=fastdata_demo;uid=root;pwd=YourPassword123" 
           DesignModel="DbFirst" 
           CacheType="web" />
      
      <!-- SQLite -->
      <Add Provider="SQLite" 
           Key="SqliteDb" 
           ConnStr="Data Source=fastdata_demo.db" 
           DesignModel="DbFirst" 
           CacheType="web" />
    </Connections>
  </DataConfig>

  <!-- Redis 配置（可选） -->
  <RedisConfig 
    AutoStart="true"
    ReadServerList="127.0.0.1:6379"
    WriteServerList="127.0.0.1:6379"
    MaxReadPoolSize="60"
    MaxWritePoolSize="60" />
</configuration>

<?xml version="1.0" encoding="utf-8"?>
<!--
  ================================================================================
  FastData 数据库配置
  
  构建说明请参阅项目根目录：
  - Directory.Build.props - MSBuild 跨平台配置
  - build.sh - Linux/Mac 构建脚本
  - build.ps1 - Windows 构建脚本（待创建）
  
  重要提醒：
  - DOTNET_SYSTEM_GLOBALIZATION_INVARIANT 仅限 net45 编译时使用
  - net6.0+/net8.0+/net10.0+ 编译和运行时绝对不能设置此变量
  - 否则 Microsoft.Data.SqlClient 会抛出 NotSupportedException
  ================================================================================
-->
<DataConfig Default="SqlServer">
  <Connections>
    <Add Key="SqlServer" Provider="Microsoft.Data.SqlClient"
         ConnStr="server=localhost;database=FastDataDemo;uid=sa;pwd=FastData@Test123;TrustServerCertificate=true;Max Pool Size=200;Min Pool Size=10;Connect Timeout=10;Command Timeout=30"
         IsDefault="true" IsOutSql="true" IsOutError="true" />
    <Add Key="MySql" Provider="MySql.Data.MySqlClient"
         ConnStr="server=127.0.0.1;database=FastDataDemo;uid=root;pwd=FastData@Test123;MaximumPoolSize=200;MinimumPoolSize=10;ConnectionTimeout=10;DefaultCommandTimeout=30;SslMode=None"
         IsOutSql="true" IsOutError="true" />
    <Add Key="PostgreSql" Provider="Npgsql"
         ConnStr="server=127.0.0.1;database=fastdatademo;uid=postgres;pwd=postgres;Maximum Pool Size=200;Minimum Pool Size=10;Timeout=10;Command Timeout=30"
         IsOutSql="true" IsOutError="true" />
    <Add Key="Sqlite" Provider="System.Data.SQLite"
         ConnStr="Data Source=fastdata_demo.db"
         IsOutSql="true" IsOutError="true" />
  </Connections>
  <Redis Server="127.0.0.1:6379" Db="7" />
</DataConfig>

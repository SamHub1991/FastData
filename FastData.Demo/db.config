<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="DataConfig" type="FastData.Config.DataConfig, FastData" />
  </configSections>
  <DataConfig Default="SqlServer">
    <Connections>
      <Add Key="SqlServer" 
           Provider="Microsoft.Data.SqlClient" 
           ConnStr="server=localhost;database=FastDataDemo;uid=sa;pwd=FastData@Test123;TrustServerCertificate=true" 
           IsDefault="true" />
      <Add Key="MySql" 
           Provider="MySql.Data.MySqlClient" 
           ConnStr="server=127.0.0.1;database=FastDataDemo;uid=root;pwd=FastData@Test123" />
      <Add Key="Sqlite" 
           Provider="System.Data.SQLite" 
           ConnStr="Data Source=fastdata_demo.db" />
      <Add Key="PostgreSql" 
           Provider="Npgsql" 
           ConnStr="server=127.0.0.1;database=fastdatademo;uid=postgres;pwd=postgres" />
    </Connections>
  </DataConfig>
</configuration>

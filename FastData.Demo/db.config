<?xml version="1.0" encoding="utf-8"?>
<!--
  ================================================================================
  FastData Demo 数据库配置
  
  配置说明：
  - 本文件为默认配置文件
  - 支持多环境配置（db.dev.config / db.pro.config 等）
  - 通过 Active 属性切换环境
  
  环境配置文件：
  - db.dev.config: 开发环境（完整日志，较小连接池）
  - db.pro.config: 生产环境（最小日志，较大连接池）
  
  使用方法：
  - 修改 Active 属性切换环境，如 Active="pro"
  - 或设置环境变量 FASTDATA_ACTIVE=pro
  ================================================================================
-->
<DataConfig Active="dev" />

<?xml version="1.0" encoding="utf-8"?>
<!--
  ================================================================================
  FastData 主配置文件
  
  配置说明：
  - Active 属性指定活跃环境名称（dev/development/pro/production/staging）
  - 存在 db.{env}.config 时优先加载对应环境配置
  - 支持环境变量 FASTDATA_ACTIVE 覆盖 Active 设置
  
  环境命名约定：
  - dev / development → db.dev.config
  - pro / production → db.pro.config
  - staging → db.staging.config
  - test → db.test.config
  ================================================================================
-->
<configuration>
  <configSections>
    <section name="DataConfig" type="FastData.Config.DataConfig, FastData" />
  </configSections>
  <!-- Active: dev/development → db.dev.config -->
  <!--         pro/production → db.pro.config -->
  <!--         staging → db.staging.config -->
  <!--         自定义 → db.{name}.config -->
  <!--         环境变量 FASTDATA_ACTIVE 优先级最高 -->
  <DataConfig Active="dev" />
</configuration>

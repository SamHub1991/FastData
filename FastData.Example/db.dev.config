<?xml version="1.0" encoding="utf-8"?>
<!--
  ================================================================================
  FastData 开发环境数据库配置（Example 项目）
  
  配置说明：
  - 本文件为开发环境（dev）专用配置
  - 通过 db.config 中的 Active="dev" 自动加载
  - Redis 使用 db=7 用于开发环境隔离
  
  连接池配置（可选）：
  - MinPoolSize: 最小连接数（默认 10，开发环境建议 5-10）
  - MaxPoolSize: 最大连接数（默认 100，开发环境建议 20-50）
  - CircuitBreakerEnabled: 是否启用熔断器（默认 true）
  ================================================================================
-->
<DataConfig Default="SqlServer">
  <Connections>
    <!-- 
      SQL Server: 主数据库
      
      属性说明：
      - Key: 连接标识名，用于代码中引用（必填）
      - Provider: 数据库提供程序（必填）
        * Microsoft.Data.SqlClient / System.Data.SqlClient → SQL Server
        * MySql.Data.MySqlClient → MySQL
        * Npgsql → PostgreSQL
        * Oracle.ManagedDataAccess.Client → Oracle
        * System.Data.SQLite → SQLite
        * IBM.Data.DB2.iSeries → DB2
      - ConnStr: 连接字符串（必填）
      - IsDefault: 是否为默认连接（可选，默认 false）
      - CacheType: 缓存类型（可选，默认 "web"）
        * web → 内存缓存（不需要 Redis）
        * redis → Redis 缓存（需要配置 Redis 节点）
      - IsOutSql: 是否输出 SQL 日志（可选，默认 true）
      - IsOutError: 是否输出错误日志（可选，默认 true）
      - DesignModel: 设计模式（可选，默认 "DbFirst"）
        * DbFirst → 数据库优先
        * CodeFirst → 代码优先
      - IsPropertyCache: 是否缓存属性（可选，默认 true）
      - SqlErrorType: SQL 错误存放类型（可选，默认 "db"）
        * db → 存入数据库
        * file → 存入文件
      - IsMapSave: Map 文件是否存数据库（可选，默认 false）
      - IsEncrypt: Map 文件是否加密（可选，默认 false）
    -->
    <Add Key="SqlServer" Provider="Microsoft.Data.SqlClient"
         ConnStr="server=localhost;database=FastDataDemo;uid=sa;pwd=FastData@Test123;TrustServerCertificate=true"
         IsDefault="true"
         CacheType="web"
         IsOutSql="true"
         DesignModel="DbFirst" />
    
    <!-- MySQL: 多数据库支持 -->
    <Add Key="MySql" Provider="MySql.Data.MySqlClient"
         ConnStr="server=127.0.0.1;database=FastDataDemo;uid=root;pwd=FastData@Test123" />
    
    <!-- PostgreSQL: 多数据库支持 -->
    <Add Key="PostgreSql" Provider="Npgsql"
         ConnStr="server=127.0.0.1;database=fastdatademo;uid=postgres;pwd=postgres" />
    
    <!-- SQLite: 本地文件数据库 -->
    <Add Key="Sqlite" Provider="System.Data.SQLite"
         ConnStr="Data Source=fastdata_example.db" />
  </Connections>
  
  <!-- 
    Redis 缓存配置
    
    属性说明：
    - Server: Redis 服务器地址，格式 host:port（默认 "127.0.0.1:6379"）
    - Db: Redis 数据库索引，0-15（默认 0）
    - Password: Redis 密码（可选，无密码留空）
    - ConnectTimeout: 连接超时，单位毫秒（默认 5000）
    - SyncTimeout: 同步超时，单位毫秒（默认 5000）
    
    注意：仅当 CacheType="redis" 时需要配置此节点
  -->
  <Redis Server="127.0.0.1:6379" Db="7" Password="" ConnectTimeout="5000" SyncTimeout="5000" />
  
  <!-- 
    连接池配置
    
    属性说明：
    - MinPoolSize: 最小连接数（默认 -1，自动计算）
      * -1 → 根据环境自动计算（推荐）
      * 正数 → 固定值，如 5
    - MaxPoolSize: 最大连接数（默认 -1，自动计算）
      * -1 → 根据环境自动计算（推荐）
      * 正数 → 固定值，如 50
      * 自动计算公式：Min(CPU*1.5, 内存MB*0.1/2)，范围 10-200
    - ConnectionTimeout: 连接超时，单位秒（默认 30）
    - ConnectionLifetime: 连接生命周期，单位分钟（默认 30）
    - HealthCheckInterval: 健康检查间隔，单位秒（默认 60）
    - LeakDetectionThreshold: 泄漏检测阈值，单位秒（默认 300）
    - EnableSmartAdjustment: 是否启用智能调整（默认 true）
      * true → 根据负载自动扩缩容
      * false → 固定连接数
    - LoadThreshold: 扩容阈值，百分比（默认 80）
      * 当连接使用率超过此值时触发扩容
    - ShrinkThreshold: 缩容阈值，百分比（默认 30）
      * 当连接使用率低于此值时触发缩容
    - MaxRetries: 连接创建最大重试次数（默认 3）
    - RetryBaseDelayMs: 重试基础延迟，单位毫秒（默认 50）
    - ValidationCommandTimeout: 连接验证命令超时，单位秒（默认 5）
    - SmartAdjustmentInterval: 智能调整间隔，单位秒（默认 30）
    - MaxExpandCount: 每次最大扩容数量（默认 10）
    - MaxShrinkCount: 每次最大缩容数量（默认 5）
    
    熔断器配置（CircuitBreaker 前缀）：
    - CircuitBreakerEnabled: 是否启用熔断器（默认 true）
    - CircuitBreakerFailureThreshold: 连续失败阈值，达到此值触发熔断（默认 5）
    - CircuitBreakerOpenDurationSec: 熔断时长，单位秒，之后进入半开状态（默认 30）
    - CircuitBreakerHalfOpenMaxRequests: 半开状态下允许的最大测试请求数（默认 3）
  -->
  <ConnectionPool
    MinPoolSize="5"
    MaxPoolSize="40"
    ConnectionTimeout="30"
    ConnectionLifetime="30"
    HealthCheckInterval="60"
    LeakDetectionThreshold="300"
    EnableSmartAdjustment="true"
    LoadThreshold="80"
    ShrinkThreshold="30"
    MaxRetries="3"
    RetryBaseDelayMs="50"
    ValidationCommandTimeout="5"
    SmartAdjustmentInterval="30"
    MaxExpandCount="10"
    MaxShrinkCount="5"
    CircuitBreakerEnabled="true"
    CircuitBreakerFailureThreshold="5"
    CircuitBreakerOpenDurationSec="30"
    CircuitBreakerHalfOpenMaxRequests="3" />
</DataConfig>

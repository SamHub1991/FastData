root = true

[*]
end_of_file = true
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
indent_style = space
indent_size = 4
csharp_style_var_for_built_in_types = false
csharp_style_var_when_type_is_apparent = true
csharp_style_var_elsewhere = false
dotnet_sort_system_directives_first = true
dotnet_style_require_accessibility_modifiers = require_for_non_interface_members
dotnet_style_readonly_field = true
csharp_style_throw_expression = true
csharp_style_pattern_matching_over_is_with_cast = true
csharp_style_pattern_matching_over_as_with_null_check = true

[*.csproj]
indent_style = space
indent_size = 2

[*.sln]
indent_style = space
indent_size = 2

[*.{xml,config,props,targets,ruleset}]
indent_style = space
indent_size = 2

[*.{json,yml,yaml,md}]
indent_style = space
indent_size = 2

[*.{sql,js,ts,html,css}]
indent_style = space
indent_size = 2

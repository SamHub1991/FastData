<?xml version="1.0" encoding="utf-8"?>
<!--
  ================================================================================
  FastData 测试环境数据库配置
  
  配置说明：
  - 本文件为测试环境（dev）专用配置
  - 通过 db.config 中的 Active="dev" 自动加载
  - 测试环境使用较小的连接池配置
  ================================================================================
-->
<DataConfig Default="SqlServer">
  <Connections>
    <!-- 
      SQL Server: 测试数据库
      
      属性说明：
      - Key: 连接标识名
      - Provider: 数据库提供程序
      - ConnStr: 连接字符串
      - IsDefault: 是否为默认连接
      - IsOutSql: 是否输出 SQL 日志（测试环境建议开启）
      - IsOutError: 是否输出错误日志（测试环境建议开启）
    -->
    <Add Key="SqlServer" Provider="Microsoft.Data.SqlClient"
         ConnStr="server=localhost;database=FastDataTest;uid=sa;pwd=FastData@Test123;TrustServerCertificate=true;Max Pool Size=200;Min Pool Size=10;Connect Timeout=10;Command Timeout=30"
         IsDefault="true" IsOutSql="true" IsOutError="true" />
    
    <!-- MySQL: 测试数据库 -->
    <Add Key="MySql" Provider="MySql.Data.MySqlClient"
         ConnStr="server=127.0.0.1;database=FastDataTest;uid=root;pwd=FastData@Test123;MaximumPoolSize=40;MinimumPoolSize=5;ConnectionTimeout=10;DefaultCommandTimeout=30;SslMode=None"
         IsOutSql="true" IsOutError="true" />
    
    <!-- PostgreSQL: 测试数据库 -->
    <Add Key="PostgreSql" Provider="Npgsql"
         ConnStr="server=127.0.0.1;database=fastdatatest;uid=postgres;pwd=FastData@Test123;Maximum Pool Size=200;Minimum Pool Size=10;Timeout=10;Command Timeout=30"
         IsOutSql="true" IsOutError="true" />
  </Connections>
  
  <!-- 
    连接池配置（测试环境）
    
    属性说明：
    - MinPoolSize: 最小连接数（测试环境建议 5）
    - MaxPoolSize: 最大连接数（测试环境建议 40）
    - ConnectionTimeout: 连接超时，单位秒
    - ConnectionLifetime: 连接生命周期，单位分钟
    - HealthCheckInterval: 健康检查间隔，单位秒
    - LeakDetectionThreshold: 泄漏检测阈值，单位秒
    - EnableSmartAdjustment: 是否启用智能调整
    - LoadThreshold: 扩容阈值，百分比
    - ShrinkThreshold: 缩容阈值，百分比
    - MaxRetries: 连接创建最大重试次数
    - RetryBaseDelayMs: 重试基础延迟，单位毫秒
    - ValidationCommandTimeout: 连接验证命令超时，单位秒
    - SmartAdjustmentInterval: 智能调整间隔，单位秒
    - MaxExpandCount: 每次最大扩容数量
    - MaxShrinkCount: 每次最大缩容数量
  -->
  <ConnectionPool
    MinPoolSize="5"
    MaxPoolSize="40"
    ConnectionTimeout="30"
    ConnectionLifetime="30"
    HealthCheckInterval="60"
    LeakDetectionThreshold="300"
    LoadThreshold="80"
    ShrinkThreshold="30"
    MaxRetries="3"
    RetryBaseDelayMs="50"
    ValidationCommandTimeout="5"
    SmartAdjustmentInterval="30"
    MaxExpandCount="10"
    MaxShrinkCount="5"
    EnableSmartAdjustment="true" />
</DataConfig>

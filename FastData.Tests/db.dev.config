<?xml version="1.0" encoding="utf-8"?>
<!--
  ================================================================================
  FastData 测试环境数据库配置
  
  配置说明：
  - 本文件为测试环境（dev）专用配置
  - 通过 db.config 中的 Active="dev" 自动加载
  - 测试环境使用较小的连接池配置
  ================================================================================
-->
<DataConfig Default="SqlServer">
  <Connections>
    <!-- 
      SQL Server: 测试数据库
      
      属性说明：
      - Key: 连接标识名（用于代码中引用此连接）
      - Provider: 数据库提供程序（Microsoft.Data.SqlClient=SQL Server, MySql.Data.MySqlClient=MySQL, Npgsql=PostgreSQL）
      - ConnStr: 连接字符串
      - IsDefault: 是否为默认连接（true/false，同一配置中只能有一个默认连接）
      - CacheType: 缓存类型（web=内存缓存, redis=Redis缓存，默认 web）
        * web → 使用内存缓存（不需要 Redis，适合单机部署）
        * redis → 使用 Redis 缓存（需要配置 RedisConfig 节点，适合分布式部署）
      - IsOutSql: 是否输出 SQL 日志（true/false，测试环境建议开启）
      - IsOutError: 是否输出错误日志（true/false，测试环境建议开启）
      - DesignModel: 设计模式（DbFirst=数据库优先, CodeFirst=代码优先，默认 DbFirst）
      - IsPropertyCache: 是否缓存实体属性（true/false，默认 true，建议开启）
      - SqlErrorType: SQL 错误存放类型（db=存入数据库, file=存入文件，默认 db）
      - IsMapSave: Map 文件是否存数据库（true/false，默认 false）
      - IsEncrypt: Map 文件是否加密（true/false，默认 false）
      - IsUpdateCache: 是否更新缓存（true/false，默认 false）
    -->
    <Add Key="SqlServer" Provider="Microsoft.Data.SqlClient"
         ConnStr="server=localhost;database=FastDataTest;uid=sa;pwd=FastData@Test123;TrustServerCertificate=true;Max Pool Size=200;Min Pool Size=10;Connect Timeout=10;Command Timeout=30"
         IsDefault="true" IsOutSql="true" IsOutError="true" CacheType="web" />
    
    <!-- 
      MySQL: 测试数据库
      
      属性说明：
      - Key: 连接标识名
      - Provider: 数据库提供程序（MySql.Data.MySqlClient=MySQL）
      - ConnStr: 连接字符串
      - CacheType: 缓存类型（web=内存缓存, redis=Redis缓存，默认 web）
      - IsOutSql: 是否输出 SQL 日志（true/false）
      - IsOutError: 是否输出错误日志（true/false）
      
      连接字符串属性说明：
      - MaximumPoolSize: 最大连接池大小
      - MinimumPoolSize: 最小连接池大小
      - ConnectionTimeout: 连接超时（秒）
      - DefaultCommandTimeout: 命令超时（秒）
      - SslMode: SSL 模式（None=禁用, Required=必需, Preferred=优先）
    -->
    <Add Key="MySql" Provider="MySql.Data.MySqlClient"
         ConnStr="server=127.0.0.1;database=FastDataTest;uid=root;pwd=FastData@Test123;MaximumPoolSize=40;MinimumPoolSize=5;ConnectionTimeout=10;DefaultCommandTimeout=30;SslMode=None"
         IsOutSql="true" IsOutError="true" CacheType="web" />
    
    <!-- 
      PostgreSQL: 测试数据库
      
      属性说明：
      - Key: 连接标识名
      - Provider: 数据库提供程序（Npgsql=PostgreSQL）
      - ConnStr: 连接字符串
      - CacheType: 缓存类型（web=内存缓存, redis=Redis缓存，默认 web）
      - IsOutSql: 是否输出 SQL 日志（true/false）
      - IsOutError: 是否输出错误日志（true/false）
      
      连接字符串属性说明：
      - Maximum Pool Size: 最大连接池大小
      - Minimum Pool Size: 最小连接池大小
      - Timeout: 连接超时（秒）
      - Command Timeout: 命令超时（秒）
    -->
    <Add Key="PostgreSql" Provider="Npgsql"
         ConnStr="server=127.0.0.1;database=fastdatatest;uid=postgres;pwd=FastData@Test123;Maximum Pool Size=200;Minimum Pool Size=10;Timeout=10;Command Timeout=30"
         IsOutSql="true" IsOutError="true" CacheType="web" />
  </Connections>
  
  <!-- 
    Redis 配置（测试环境）
    
    属性说明：
    - WriteServerList: 写服务器列表（格式：ip:port，多个用逗号分隔）
    - ReadServerList: 读服务器列表（格式：ip:port，多个用逗号分隔）
    - MaxWritePoolSize: 最大写连接数（建议：60-200）
    - MaxReadPoolSize: 最大读连接数（建议：60-200）
    - AutoStart: 是否自动启动连接池（true/false）
    - Password: Redis 密码（无密码可省略此属性）
    - Db: Redis 数据库索引（默认 0，范围 0-15）
    - ConnectTimeout: 连接超时（毫秒，默认 5000）
    - SyncTimeout: 同步超时（毫秒，默认 5000）
    - ResponseTimeout: 响应超时（毫秒，默认 5000）
  -->
  <RedisConfig
    WriteServerList="127.0.0.1:6379"
    ReadServerList="127.0.0.1:6379"
    MaxWritePoolSize="60"
    MaxReadPoolSize="60"
    AutoStart="true" />
  
  <!-- 
    连接池配置（测试环境）
    
    属性说明：
    - MinPoolSize: 最小连接数（建议：5-10，测试环境可设较小值）
    - MaxPoolSize: 最大连接数（建议：40-200，根据服务器资源调整）
    - ConnectionTimeout: 连接超时时间，单位秒（建议：10-30）
    - ConnectionLifetime: 连接生命周期，单位分钟（建议：15-30，0表示不限制）
    - HealthCheckInterval: 健康检查间隔，单位秒（建议：30-60）
    - LeakDetectionThreshold: 泄漏检测阈值，单位秒（建议：120-300，超过此时间未释放的连接会被记录）
    - EnableSmartAdjustment: 是否启用智能调整（true/false，根据负载自动扩缩容）
    - LoadThreshold: 扩容阈值，百分比（建议：70-85，负载超过此值时扩容）
    - ShrinkThreshold: 缩容阈值，百分比（建议：20-35，负载低于此值时缩容）
    - MaxRetries: 连接创建最大重试次数（建议：2-5）
    - RetryBaseDelayMs: 重试基础延迟，单位毫秒（建议：50-200，采用指数退避策略）
    - ValidationCommandTimeout: 连接验证命令超时，单位秒（建议：3-5）
    - SmartAdjustmentInterval: 智能调整间隔，单位秒（建议：15-60）
    - MaxExpandCount: 每次最大扩容数量（建议：5-10）
    - MaxShrinkCount: 每次最大缩容数量（建议：3-5）
    - ErrorShrinkThreshold: 异常缩容阈值，连续失败次数（建议：3-5）
    - ErrorShrinkPercentage: 异常缩容比例，百分比（建议：20-50）
    - EnableRedisCheck: 是否启用 Redis 可用性检测（true/false，Redis 可用时才允许扩容）
    - RedisConnectionString: Redis 连接字符串（用于可用性检测）
  -->
  <ConnectionPool
    MinPoolSize="5"
    MaxPoolSize="40"
    ConnectionTimeout="30"
    ConnectionLifetime="30"
    HealthCheckInterval="60"
    LeakDetectionThreshold="300"
    LoadThreshold="80"
    ShrinkThreshold="30"
    MaxRetries="3"
    RetryBaseDelayMs="50"
    ValidationCommandTimeout="5"
    SmartAdjustmentInterval="30"
    MaxExpandCount="10"
    MaxShrinkCount="5"
    EnableSmartAdjustment="true"
    ErrorShrinkThreshold="3"
    ErrorShrinkPercentage="20"
    EnableRedisCheck="false" />
  
  <!-- 
    IM 平台配置（测试环境）
    
    用于异常通知和远程指令管理
    支持 QQ 机器人、企业微信、钉钉等 IM 平台
  -->
  <IMPlatform>
    <!-- 
      QQ 机器人配置
      
      属性说明：
      - IsEnabled: 是否启用 QQ 机器人（true/false）
      - BotId: 机器人 ID（QQ 号）
      - BotToken: 机器人 Token（用于 API 认证）
      - ApiUrl: API 地址（如 http://127.0.0.1:5700，Go-CQHTTP 默认端口）
      - CommandPrefix: 指令前缀（默认 #，如 #status）
      - RequireAdminForCommands: 是否需要管理员权限才能执行指令（true/false）
      
      子节点说明：
      - AdminQQNumbers: 管理员 QQ 号列表
      - NotifyGroups: 通知群号列表（异常信息会发送到这些群）
      - NotifyUsers: 通知个人 QQ 号列表（异常信息会发送给这些用户）
    -->
    <QQBot 
      IsEnabled="false" 
      BotId="" 
      BotToken="" 
      ApiUrl="http://127.0.0.1:5700" 
      CommandPrefix="#" 
      RequireAdminForCommands="true">
      <AdminQQNumbers>
        <!-- <Add Value="123456789" /> -->
      </AdminQQNumbers>
      <NotifyGroups>
        <!-- <Add Value="987654321" /> -->
      </NotifyGroups>
      <NotifyUsers>
        <!-- <Add Value="111222333" /> -->
      </NotifyUsers>
    </QQBot>
    
    <!-- 
      异常通知配置
      
      属性说明：
      - IsEnabled: 是否启用异常通知（true/false）
      - MinNotifyIntervalSeconds: 最小通知间隔，单位秒（建议：60-300，防止重复通知）
      - SendStackTrace: 是否发送堆栈信息（true/false，调试时建议开启）
      - MaxStackTraceLength: 最大堆栈长度（建议：500-1000，过长会被截断）
      - MinLevel: 只通知指定级别以上的异常（可选值：Debug, Info, Warning, Error, Critical）
    -->
    <ExceptionNotify 
      IsEnabled="true" 
      MinNotifyIntervalSeconds="60" 
      SendStackTrace="true" 
      MaxStackTraceLength="500" 
      MinLevel="Error" />
  </IMPlatform>
</DataConfig>

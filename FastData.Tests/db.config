<?xml version="1.0" encoding="utf-8"?>
<DataConfig Default="SqlServer">
  <Connections>
    <Add Key="SqlServer" Provider="Microsoft.Data.SqlClient"
         ConnStr="server=localhost;database=FastDataTest;uid=sa;pwd=FastData@Test123;TrustServerCertificate=true;Max Pool Size=200;Min Pool Size=10;Connect Timeout=10;Command Timeout=30"
         IsDefault="true" IsOutSql="true" IsOutError="true" />
    <Add Key="MySql" Provider="MySql.Data.MySqlClient"
         ConnStr="server=127.0.0.1;database=FastDataTest;uid=root;pwd=FastData@Test123;MaximumPoolSize=200;MinimumPoolSize=10;ConnectionTimeout=10;DefaultCommandTimeout=30;SslMode=None"
         IsOutSql="true" IsOutError="true" />
    <Add Key="PostgreSql" Provider="Npgsql"
         ConnStr="server=127.0.0.1;database=fastdatatest;uid=postgres;pwd=FastData@Test123;Maximum Pool Size=200;Minimum Pool Size=10;Timeout=10;Command Timeout=30"
         IsOutSql="true" IsOutError="true" />
  </Connections>
  <!-- 连接池配置（可选，无配置则使用默认值）
    基础配置:
      - MinPoolSize: 最小连接数（默认 10，建议 5-20）
      - MaxPoolSize: 最大连接数（默认 100，建议 50-200）
      - ConnectionTimeout: 获取连接超时秒数（默认 30）
      - ConnectionLifetime: 连接生命周期秒数（默认 30，过期连接会被替换）
      - HealthCheckInterval: 健康检查间隔秒数（默认 60）
      - LeakDetectionThreshold: 连接泄漏检测阈值秒数（默认 300，超过提示警告）
    智能调整:
      - EnableSmartAdjustment: 是否启用智能调整（默认 true）
      - LoadThreshold: 扩容阈值百分比（默认 80，活跃连接/总连接 > 80% 触发扩容）
      - ShrinkThreshold: 缩容阈值百分比（默认 30，活跃连接/总连接 < 30% 触发缩容）
      - MaxExpandCount: 每次最大扩容数量（默认 10）
      - MaxShrinkCount: 每次最大缩容数量（默认 5）
      - SmartAdjustmentInterval: 智能调整间隔秒数（默认 30）
    重试机制:
      - MaxRetries: 连接创建最大重试次数（默认 3）
      - RetryBaseDelayMs: 重试基础延迟毫秒（默认 50，指数退避）
      - ValidationCommandTimeout: 连接验证命令超时秒数（默认 5）
    熔断器 (Circuit Breaker):
      - CircuitBreakerEnabled: 是否启用熔断器（默认 true）
      - CircuitBreakerFailureThreshold: 连续失败阈值（默认 5，达到此值触发熔断）
      - CircuitBreakerOpenDurationSec: 熔断时长秒数（默认 30，之后进入半开状态）
      - CircuitBreakerHalfOpenMaxRequests: 半开状态最大测试请求数（默认 3）
  -->
  <ConnectionPool
    MinPoolSize="10"
    MaxPoolSize="100"
    ConnectionTimeout="30"
    ConnectionLifetime="30"
    HealthCheckInterval="60"
    LeakDetectionThreshold="300"
    LoadThreshold="80"
    ShrinkThreshold="30"
    MaxRetries="3"
    RetryBaseDelayMs="50"
    ValidationCommandTimeout="5"
    SmartAdjustmentInterval="30"
    MaxExpandCount="10"
    MaxShrinkCount="5"
    EnableSmartAdjustment="true"
    CircuitBreakerEnabled="true"
    CircuitBreakerFailureThreshold="5"
    CircuitBreakerOpenDurationSec="30"
    CircuitBreakerHalfOpenMaxRequests="3" />
  <!-- IM 平台配置（默认不启用，配置后启用） -->
  <IMPlatform>
    <QQBot IsEnabled="false"
           BotId=""
           BotToken=""
           ApiUrl="http://127.0.0.1:5700"
           CommandPrefix="#"
           RequireAdminForCommands="true">
      <!-- 管理员 QQ 号列表（个人用户） -->
      <AdminQQNumbers>
        <!-- <Add Value="123456789" /> -->
      </AdminQQNumbers>
      <!-- 通知群号列表 -->
      <NotifyGroups>
        <!-- <Add Value="987654321" /> -->
      </NotifyGroups>
      <!-- 通知个人 QQ 号列表 -->
      <NotifyUsers>
        <!-- <Add Value="123456789" /> -->
      </NotifyUsers>
    </QQBot>
    <ExceptionNotify IsEnabled="true"
                    MinNotifyIntervalSeconds="60"
                    SendStackTrace="true"
                    MaxStackTraceLength="500"
                    MinLevel="Error" />
  </IMPlatform>
</DataConfig>

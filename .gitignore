# 编译输出
bin/
obj/
*.dll
*.exe
*.so
*.dylib

# 项目特定文件
*.nupkg
*.snk
*.pfx
appsettings.local.json

# 日志文件
*.log
Log/
logs/

# 数据库文件（SQLite 等）
*.db
*.sqlite
*.sqlite3

# 用户特定配置
*.user
.vscode/
.idea/
*.suo
*.iml

# 操作系统文件
.DS_Store
Thumbs.db

# 临时文件
tmp/
temp/
*.tmp

# 测试输出
TestResults/
coverage/
*.coverage
*.coveragexml

# NuGet 包
packages/
.nuget/

# Docker 数据卷（如果本地挂载）
docker/*/data/

# Node.js（如果有前端项目）
node_modules/
npm-debug.log

# Python（如果有脚本）
__pycache__/
*.py[cod]
.env
.venv/
